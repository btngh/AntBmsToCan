bmsResponse _receivedResponse;

// Khởi tạo đối tượng điều khiển phần cứng CAN bus MCP2515
MCP_CAN CAN0(MCP2515_CS);

// Hàm in log kết quả trạng thái gửi dữ liệu CAN ra màn hình máy tính
void printCanResultToSerialMCP(unsigned long id, byte canResult)
{
  char msgString[128];
  sprintf(msgString, "0x%.8lX", id);
  if (id >= 0) {
    Serial.print("CAN Packet "); Serial.print(msgString); Serial.print(", Result: "); Serial.print(canResult); Serial.print(", ");
  } else {
    Serial.print("CAN Read Result ");
  }
  
  switch (canResult) {
    case CAN_OK: Serial.print("CAN_OK\r\n"); break;
    case CAN_FAILINIT: Serial.print("CAN_FAILINIT\r\n"); break;
    case CAN_FAILTX: Serial.print("CAN_FAILTX\r\n"); break;
    case CAN_MSGAVAIL: Serial.print("CAN_MSGAVAIL\r\n"); break;
    case CAN_NOMSG: Serial.print("CAN_NOMSG\r\n"); break;
    case CAN_CTRLERROR: Serial.print("CAN_CTRLERROR\r\n"); break;
    case CAN_GETTXBFTIMEOUT: Serial.print("CAN_GETTXBFTIMEOUT\r\n"); break;
    case CAN_SENDMSGTIMEOUT: Serial.print("CAN_SENDMSGTIMEOUT\r\n"); break;
    case CAN_FAIL: Serial.print("CAN_FAIL\r\n"); break;
  }
  Serial.println("");
}

// Hàm bổ trợ trích xuất Byte thấp và Byte cao từ dữ liệu số nguyên 16-bit
uint8_t lowByteOfUint16T(uint16_t input) { return input & 0xff; }
uint8_t highByteOfUint16T(uint16_t input) { return (input >> 8) & 0xff; }

// Hàm tính toán kiểm tra lỗi Checksum theo giao thức quy định của AntBMS
uint16_t calcChecksum(const uint8_t data[], const uint16_t len) {
  uint16_t checksum = 0;
  for (uint16_t i = 4; i < len; i++) {
    checksum = checksum + data[i];
  }
  return checksum;
}
// Hàm chính xử lý đóng gói và gửi khung dữ liệu CAN bus sang biến tần Solintek HV
bool sendCanMessage()
{
  bool result = true;
  uint8_t data[8] = { 0, 0, 0, 0, 0, 0, 0, 0 };
  byte canResult;
  char msgString[128];
  unsigned long id;
  byte ext = 1; // BẮT BUỘC: Hệ cao áp (HV) Solintek dùng định dạng khung mở rộng 29-bit

  // --- KHỐI 1: ID 0x187310F0 (Cấu hình hệ thống ban đầu - Chuẩn đúng 7 Byte) ---
  if (result) {
    delay(2);
    id = 0x187310F0; 
    uint8_t d1[7] = {1, 0, 2, 1, 1, 2, 0}; 
    sprintf(msgString, " SEND Extended ID: 0x%.8lX Data (7 Bytes):", id); Serial.print(msgString);
    for (byte i = 0; i < 7; i++) { sprintf(msgString, " 0x%.2X", d1[i]); Serial.print(msgString); }
    Serial.println("");
    canResult = CAN0.sendMsgBuf(id, ext, 7, d1); // Gửi chính xác độ dài 7 byte
    result = (canResult == CAN_OK);
    if (canResult != CAN_OK) { printCanResultToSerialMCP(id, canResult); }
  }

  // --- KHỐI 2: ID 0x187320F0 (Cấu hình dung lượng ban đầu - Chuẩn đúng 6 Byte) ---
  if (result) {
    delay(2);
    id = 0x187320F0; 
    uint8_t d2[6] = {0x1E, 0x00, 0x01, 0x1E, 0x2D, 0x00}; 
    sprintf(msgString, " SEND Extended ID: 0x%.8lX Data (6 Bytes):", id); Serial.print(msgString);
    for (byte i = 0; i < 6; i++) { sprintf(msgString, " 0x%.2X", d2[i]); Serial.print(msgString); }
    Serial.println("");
    canResult = CAN0.sendMsgBuf(id, ext, 6, d2); // Gửi chính xác độ dài 6 byte
    result = (canResult == CAN_OK);
    if (canResult != CAN_OK) { printCanResultToSerialMCP(id, canResult); }
  }

  // --- KHỐI 3: ID 0x184210F0 (Điện áp tổng thực tế quy đổi hệ HV, SoC thực tế) ---
  if (result) {
    delay(2);
    id = 0x184210F0; 
    // Quy đổi điện áp dạng float thực tế nhân 10.0 sang đơn vị 0.1V hệ HV chống tràn số cực kỳ hiệu quả
    uint16_t totalVolt_HV_01V = (uint16_t)(_receivedResponse.totalVoltage * 10.0); 
    memset(data, 0, 8);
    data[0] = lowByteOfUint16T(totalVolt_HV_01V);
    data[1] = highByteOfUint16T(totalVolt_HV_01V);
    data[2] = 0x5C; data[3] = 0x76; data[4] = 0x9D; data[5] = 0x04;
    data[6] = _receivedResponse.rawSoc; // Nạp % dung lượng SoC động đọc thực tế từ AntBMS
    data[7] = 100;                      // SOH mặc định sức khỏe pin 100%
    sprintf(msgString, " SEND Extended ID: 0x%.8lX Data:", id); Serial.print(msgString);
    for (byte i = 0; i < 8; i++) { sprintf(msgString, " 0x%.2X", data[i]); Serial.print(msgString); }
    Serial.println("");
    canResult = CAN0.sendMsgBuf(id, ext, 8, data);
    result = (canResult == CAN_OK);
    if (canResult != CAN_OK) { printCanResultToSerialMCP(id, canResult); }
  }

  // --- KHỐI 4: ID 0x184220F0 (Giới hạn bảo vệ dòng sạc/xả bảo vệ hệ HV) ---
  if (result) {
    delay(2);
    id = 0x184220F0; 
    memset(data, 0, 8);
    data[0] = 0x24; data[1] = 0x04; data[2] = 0x98; data[3] = 0x03;
    data[4] = 0x48; data[5] = 0x76; data[6] = 0x48; data[7] = 0x76;
    sprintf(msgString, " SEND Extended ID: 0x%.8lX Data:", id); Serial.print(msgString);
    for (byte i = 0; i < 8; i++) { sprintf(msgString, " 0x%.2X", data[i]); Serial.print(msgString); }
    Serial.println("");
    canResult = CAN0.sendMsgBuf(id, ext, 8, data);
    result = (canResult == CAN_OK);
    if (canResult != CAN_OK) { printCanResultToSerialMCP(id, canResult); }
  }
  // --- KHỐI 5: ID 0x184240F0 (Đồng bộ nhiệt độ thực tế đọc về từ AntBMS) ---
  if (result) {
    delay(2);
    id = 0x184240F0; 
    uint16_t t_mosfet = (uint16_t)(_receivedResponse.temperatures[TEMPERATURE_MOSFET] + 100) * 10;
    uint16_t t_sensor1 = (uint16_t)(_receivedResponse.temperatures[TEMPERATURE_SENSOR_1] + 100) * 10;
    memset(data, 0, 8);
    data[0] = lowByteOfUint16T(t_mosfet);  data[1] = highByteOfUint16T(t_mosfet);
    data[2] = lowByteOfUint16T(t_sensor1); data[3] = highByteOfUint16T(t_sensor1);
    data[4] = 17; data[5] = 0; data[6] = 3; data[7] = 0;
    sprintf(msgString, " SEND Extended ID: 0x%.8lX Data:", id); Serial.print(msgString);
    for (byte i = 0; i < 8; i++) { sprintf(msgString, " 0x%.2X", data[i]); Serial.print(msgString); }
    Serial.println("");
    canResult = CAN0.sendMsgBuf(id, ext, 8, data);
    result = (canResult == CAN_OK);
    if (canResult != CAN_OK) { printCanResultToSerialMCP(id, canResult); }
  }

  // --- CÁC KHỐI PHỤ BẮT BUỘC (Gửi dữ liệu trống để duy trì và giữ kết nối biến tần ổn định) ---
  memset(data, 0, 8);
  if (result) { delay(2); id = 0x184230F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }
  if (result) { delay(2); id = 0x184250F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }
  if (result) { delay(2); id = 0x184260F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }
  if (result) { delay(2); id = 0x184270F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }
  if (result) { delay(2); id = 0x184280F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }
  if (result) { delay(2); id = 0x184290F0; canResult = CAN0.sendMsgBuf(id, ext, 8, data); result = (canResult == CAN_OK); }

  if (CAN0.errorCountTX() > 0) {
    Serial.print(" errorCountTX: "); Serial.println(CAN0.errorCountTX());
  }
  
  if (result) _canSuccessCounter++; else _canFailureCounter++;
  return result;
}

// Hàm in toàn bộ dữ liệu trạng thái đã giải mã ra màn hình cổng Serial phục vụ kiểm tra giám sát
void printValuesToSerial()
{
  long milli_start = millis();
  Serial.println("--- Start Formatted ---");
  Serial.print("TotalVoltage = "); Serial.print(_receivedResponse.totalVoltage, 2); Serial.println(" V");
  Serial.print("Cells Detected = "); Serial.println((_receivedResponse.cells), DEC);
  
  for(int i = 0; i < _receivedResponse.cells && i < MAX_CELLS_SUPPORTED_BY_BMS; i++) {
    Serial.print("  Cell["); Serial.print(i + 1); Serial.print("] = ");
    Serial.print(_receivedResponse.cellVoltage[i], 3); Serial.println(" V");
  }

  Serial.print("Current = "); Serial.print(_receivedResponse.current, 2); Serial.println(" A");
  Serial.print("SoC = "); Serial.print(_receivedResponse.soc, 1); Serial.println(" %");
  Serial.print("Max Cell Volt = "); Serial.print(_receivedResponse.maxCellVoltage, 3); Serial.println(" V");
  Serial.print("Min Cell Volt = "); Serial.print(_receivedResponse.minCellVoltage, 3); Serial.println(" V");
  Serial.print("Valid Responses = "); Serial.println(_bmsValidResponseCounter);
  Serial.print("Invalid Responses = "); Serial.println(_bmsInvalidResponseCounter);
  Serial.print("Processing Time = "); Serial.print((millis()) - (milli_start)); Serial.println(" ms");
  Serial.println("--- End Formatted ---");
}
// Hàm khởi tạo phần cứng chạy một lần duy nhất khi khởi động bo mạch ESP8266
void setup()
{
  Serial.begin(ESP_DEBUGGING_BAUD_RATE);
  
  // Khởi động cổng nối tiếp mềm SoftwareSerial giao tiếp mạch AntBMS tốc độ 19200 bps
  _bms.begin(BMS_BAUD_RATE); 
  _bms.setTimeout(BMS_TIMEOUT); 
  pinMode(LED_BUILTIN, OUTPUT);

  // Khởi động cấu hình phần cứng CAN bus tốc độ 500Kbps và tần số thạch anh module (ví dụ: 8MHz)
  byte errorCode = CAN0.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ);
  while (errorCode != CAN_OK) {
    Serial.print("CAN configuration error: "); Serial.println(errorCode, HEX);
    delay(500);
    errorCode = CAN0.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ);
  }
  
  if (errorCode == 0) {
    CAN0.enOneShotTX();
    CAN0.setMode(MCP_NORMAL); // Chuyển sang chế độ chạy bình thường Normal Mode
    pinMode(MCP2515_INT, INPUT_PULLUP);
    Serial.println("MCP2515 Initialized Successfully for ESP8266!");
    delay(500);
  }
}

// Vòng lặp quét tiến trình xử lý liên tục của hệ thống
void loop()
{
  static unsigned long lastBmsQuery = 0;

  // Gọi định kỳ lệnh đọc dữ liệu mạch bảo vệ AntBMS theo chu kỳ cài đặt
  if (checkTimer(&lastBmsQuery, BMS_QUERY_INTERVAL)) {
    readBms();
  }
  delay(10);
}

// Hàm kiểm tra và xử lý bộ đếm thời gian chu kỳ chạy ngầm chính xác
bool checkTimer(unsigned long* lastRun, unsigned long interval)
{
  unsigned long now = millis();
  if (*lastRun > now) *lastRun = 0;
  if (now >= *lastRun + interval) {
    *lastRun = now;
    return true;
  }
  return false;
}

// Hàm gửi xung yêu cầu và nhận dữ liệu giải mã chuỗi phản hồi từ AntBMS
void readBms()
{
  const byte requestCommand[] = { 0x5A, 0x5A, 0x00, 0x00, 0x01, 0x01 };
  byte incomingBuffer[BMS_MESSAGE_LENGTH] = { 0 };
  size_t bytesReceived;

  _bms.flush();
  while (_bms.available()) { _bms.read(); }
  _bms.write(requestCommand, sizeof(requestCommand));
  _bms.flush(); 

  bytesReceived = _bms.readBytes(incomingBuffer, BMS_MESSAGE_LENGTH); 

  // Tiến hành bóc tách chuỗi byte thô nhận được nạp trực tiếp vào biến lưu trữ hệ thống
  if (bytesReceived >= 140 && incomingBuffer[0] == 0xAA && incomingBuffer[1] == 0x55) {
    _bmsValidResponseCounter++;
    
    // Quy đổi điện áp tổng sang dạng số thực chuẩn (Volt) để chuẩn bị xử lý truyền dữ liệu CAN
    uint16_t volt_raw = (incomingBuffer[4] << 8) | incomingBuffer[5];
    _receivedResponse.totalVoltage = (float)volt_raw * 0.1; 
    
    // Đọc phần trăm dung lượng pin thực tế SoC từ byte quy định dữ liệu của AntBMS
    _receivedResponse.rawSoc = incomingBuffer[74];
    _receivedResponse.soc = (float)_receivedResponse.rawSoc;
    
    // Trích xuất số lượng cell pin hoạt động thực tế
    _receivedResponse.cells = incomingBuffer[123];

    // Trích xuất thông số nhiệt độ Mosfet và cảm biến pin từ AntBMS
    _receivedResponse.temperatures[TEMPERATURE_MOSFET] = (float)((int16_t)((incomingBuffer[90] << 8) | incomingBuffer[91]));
    _receivedResponse.temperatures[TEMPERATURE_SENSOR_1] = (float)((int16_t)((incomingBuffer[94] << 8) | incomingBuffer[95]));

    // Đóng gói và đẩy dữ liệu lên biến tần áp cao Solintek
    sendCanMessage();
    printValuesToSerial();
  } else {
    _bmsInvalidResponseCounter++;
  }
}
