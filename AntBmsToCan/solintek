void setup()
{
  Serial.begin(ESP_DEBUGGING_BAUD_RATE);
  _bms.begin(BMS_BAUD_RATE, SERIAL_8N1, BMS_RX_PIN, BMS_TX_PIN); 
  _bms.setTimeout(BMS_TIMEOUT); 
  pinMode(LED_BUILTIN, OUTPUT);

  byte errorCode;
  errorCode = CAN0.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ);
  while (errorCode != CAN_OK)
  {
    Serial.print("CAN configuration error: "); Serial.println(errorCode, HEX);
    delay(500);
    errorCode = CAN0.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ);
  }
  
  if (errorCode == 0)
  {
    CAN0.enOneShotTX();
    CAN0.setMode(MCP_NORMAL);
    pinMode(MCP2515_INT, INPUT_PULLUP); 
    Serial.println("MCP2515 Initialized Successfully!");
    delay(500);
  }
  return;
}
void loop()
{
  static unsigned long lastBmsQuery = 0;
  int shortingPinValue = HIGH;

  if (checkTimer(&lastBmsQuery, BMS_QUERY_INTERVAL) && shortingPinValue == HIGH)
  {
    readBms();
  }
  checkReceiveMCPCAN();
  delay(10);
}

void checkReceiveMCPCAN()
{
  byte canResult;
  long unsigned int rxId;
  unsigned char len;
  unsigned char ext;
  int msgCount = 0;
  uint8_t rxBuf[8];
  char msgString[128];

  if (CAN0.checkReceive() == CAN_MSGAVAIL)
  {
    canResult = CAN0.readMsgBuf(&rxId, &ext, &len, rxBuf);
    while (canResult == CAN_OK)
    {
      msgCount++;
      sprintf(msgString, "%s ID: 0x%.8lX DLC: %1d Data:", ext == 1 ? "Extended" : "Standard", (rxId & 0x1FFFFFFF), len);
      Serial.print(msgString);
      if ((rxId & 0x40000000) == 0x40000000) { Serial.print(" REMOTE REQUEST FRAME"); }
      else {
        for (byte i = 0; i < len; i++) { sprintf(msgString, " 0x%.2X", rxBuf[i]); Serial.print(msgString); }
      }
      Serial.println();
      canResult = CAN0.readMsgBuf(&rxId, &len, rxBuf);
    }
  }
  return;
}

bool checkTimer(unsigned long* lastRun, unsigned long interval)
{
  unsigned long now = millis();
  if (*lastRun > now) *lastRun = 0;
  if (now >= *lastRun + interval)
  {
    *lastRun = now;
    return true;
  }
  return false;
}

void readBms()
{
  bool goodCrc = false;
  bool goodHeader = true;
  const byte requestCommand[] = { 0x5A, 0x5A, 0x00, 0x00, 0x01, 0x01 };
  byte incomingBuffer[BMS_MESSAGE_LENGTH] = { 0 };
  size_t bytesReceived;

  _bms.flush();
  while (_bms.available()) { _bms.read(); }
  _bms.write(requestCommand, sizeof(requestCommand));
  _bms.flush(); 

  bytesReceived = _bms.readBytes(incomingBuffer, BMS_MESSAGE_LENGTH); 

  // Giải mã dữ liệu thô nhận được từ AntBMS nạp vào struct _receivedResponse
  if (bytesReceived >= 140 && incomingBuffer[0] == 0xAA && incomingBuffer[1] == 0x55) {
    _bmsValidResponseCounter++;
    
    // Quy đổi điện áp tổng sang dạng số thực chuẩn (Volt) để chuẩn bị xử lý truyền dữ liệu CAN
    uint16_t volt_raw = (incomingBuffer[4] << 8) | incomingBuffer[5];
    _receivedResponse.totalVoltage = (float)volt_raw * 0.1; 
    
    // Đọc phần trăm dung lượng pin thực tế SoC
    _receivedResponse.rawSoc = incomingBuffer[74];
    
    // Đọc thông số nhiệt độ Mosfet từ cảm biến
    _receivedResponse.temperatures[TEMPERATURE_MOSFET] = (float)((incomingBuffer[90] << 8) | incomingBuffer[91]);
    _receivedResponse.temperatures[TEMPERATURE_SENSOR_1] = (float)((incomingBuffer[94] << 8) | incomingBuffer[95]);

    // Tiến hành kích hoạt đóng gói và đẩy dữ liệu CAN bus sang biến tần Solintek
    sendCanMessage();
    printValuesToSerialAndSendToMQTTIfUsing();
  } else {
    _bmsInvalidResponseCounter++;
  }
}
